rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    // recruiter, hiring-manager and admin are the internal "staff" roles —
    // candidates never read/write these collections.
    function isStaff() {
      return isSignedIn() && userRole() in ['admin', 'recruiter', 'hiring-manager'];
    }

    match /Users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
    }

    match /Positions/{positionId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /Counters/{counterId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /Requisitions/{requisitionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();

      match /approvals/{level} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update: if isSignedIn() && request.auth.uid == resource.data.approverId;
      }
    }

    // Job adverts. The public (including signed-out visitors) may only see
    // live, external, non-confidential career-site adverts. Public queries
    // MUST filter on all four fields so list reads can be proven safe.
    match /Jobs/{jobId} {
      allow read: if isStaff()
        || (resource.data.status in ['Active', 'Re-advertised']
            && resource.data.showOnCareerSite == true
            && resource.data.isConfidential == false
            && resource.data.advertType == 'external');
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Applications: candidates create their own (with the mandatory
    // declaration), read their own, and can NEVER amend or delete them
    // after submission. Staff manage the pipeline.
    match /Applications/{applicationId} {
      allow read: if isStaff()
        || (isSignedIn() && resource.data.candidateId == request.auth.uid);
      allow create: if isStaff()
        || (isSignedIn()
            && request.resource.data.candidateId == request.auth.uid
            && request.resource.data.consentGiven == true
            && request.resource.data.status == 'applied');
      allow update: if isStaff();
      allow delete: if false;

      // Panel collaboration comments (shortlisting rationale, notes).
      match /comments/{commentId} {
        allow read, create: if isStaff();
        allow update, delete: if false;
      }
    }

    match /Interviews/{interviewId} {
      allow read: if isStaff()
        || (isSignedIn() && resource.data.candidateId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /Offers/{offerId} {
      allow read: if isStaff()
        || (isSignedIn() && resource.data.candidateId == request.auth.uid);
      allow create: if isStaff();
      // Staff manage offers; a candidate may only flip their own 'sent'
      // offer to accepted/rejected (nothing else).
      allow update: if isStaff()
        || (isSignedIn()
            && resource.data.candidateId == request.auth.uid
            && resource.data.status == 'sent'
            && request.resource.data.status in ['accepted', 'rejected']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /ReferenceChecks/{checkId} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // In-app notification log (also the outbox for a future email sender).
    match /Notifications/{notificationId} {
      allow read: if isStaff()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    // Shared pre-screening question library (single document).
    match /QuestionBank/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Email/interview/advert templates: staff use them, admins manage them.
    match /Templates/{templateId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // Hiring workflows: staff read (the job builder offers them); admins manage.
    match /Workflows/{workflowId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }
  }
}