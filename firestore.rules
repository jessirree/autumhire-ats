  rules_version = '2';

  service cloud.firestore {
    match /databases/{database}/documents {

      function isSignedIn() {
        return request.auth != null;
      }

      function userRole() {
        return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role;
      }

      function isAdmin() {
        return isSignedIn() && userRole() == 'admin';
      }

      // recruiter, hiring-manager and admin are the internal "staff" roles —
      // candidates never read/write these collections.
      function isStaff() {
        return isSignedIn() && userRole() in ['admin', 'recruiter', 'hiring-manager'];
      }

      match /Users/{userId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow update: if isAdmin()
          || (request.auth.uid == userId
              && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      }

      match /Positions/{positionId} {
        allow read: if isStaff();
        allow write: if isAdmin();
      }

      match /Counters/{counterId} {
        allow read: if isStaff();
        allow write: if isStaff();
      }

      match /Requisitions/{requisitionId} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update: if isStaff();

        match /approvals/{level} {
          allow read: if isStaff();
          allow create: if isStaff();
          allow update: if isSignedIn() && request.auth.uid == resource.data.approverId;
        }
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
